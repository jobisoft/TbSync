{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "tbsync@jobisoft.de",
      "update_url": "https://raw.githubusercontent.com/jobisoft/tbsync/refs/heads/Main/updates.json",
      "strict_min_version": "140.0",
      "strict_max_version": "151.*"
    }
  },
  "name": "TbSync Manager",
  "version": "5.0.10",
  "author": "John Bieling",
  "homepage_url": "https://github.com/jobisoft/TbSync",
  "default_locale": "en-US",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "32": "icons/tbsync-32.png",
    "64": "icons/tbsync-64.png"
  },
  "browser_action": {
    "default_title": "TbSync",
    "default_icon": {
      "32": "icons/tbsync-32.png",
      "64": "icons/tbsync-64.png"
    },
    "default_label": "",
    "allowed_spaces": []
  },
  "permissions": [
    "storage",
    "alarms",
    "management",
    "addressBooks",
    "menus",
    "menus.overrideContext",
    "notifications",
    "compose"
  ],
  "background": {
    "type": "module",
    "scripts": ["background.mjs"]
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "experiment_apis": {
    "LegacyPrefs": {
      "schema": "experiments/LegacyPrefs/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["LegacyPrefs"]],
        "script": "experiments/LegacyPrefs/implementation.js"
      }
    },
    "ProfileFiles": {
      "schema": "experiments/ProfileFiles/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["ProfileFiles"]],
        "script": "experiments/ProfileFiles/implementation.js"
      }
    }
  }
}
